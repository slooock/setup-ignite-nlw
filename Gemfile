# nokogiri: CVE-2022-23437, CVE-2022-29181 (XXE vulnerabilities)
gem 'nokogiri', '1.12.5'

# loofah: CVE-2022-23515 (XSS sanitizer bypass)
gem 'loofah', '2.12.0'

# rack: CVE-2022-30122, CVE-2022-30123 (DoS and Shell injection)
gem 'rack', '2.2.3'
